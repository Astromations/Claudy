# Excluded from the packaged .vsix
# These files won't be bundled when you run `vsce package`

# Font file — cannot be used by a theme, distribute separately
*.ttf
*.otf
*.woff
*.woff2

# Development / system files
.git/**
.gitignore
.DS_Store
Thumbs.db
*.zip

